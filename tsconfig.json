{
  "compilerOptions": {
    "noEmit": true,
    "target": "ESNext",
    "module": "ESNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": ["vite/client", "node", "grecaptcha"],
    "paths": { "src/*": ["./src/*"] },
    "outDir": "ts-out",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true
  }
}
